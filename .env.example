# Copy to .env and fill in real values. Never commit .env.
NODE_ENV=production

# --- Database ---
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change_me

# --- Reverse proxy / domain ---
# Domain Caddy will request HTTPS certs for (use localhost for local dev)
SITE_DOMAIN=localhost

# --- CORS ---
# Explicit single origin — never a wildcard. Must match the storefront's real URL.
CORS_ORIGIN=http://localhost

# --- Admin auth (JWT) ---
# Generate with: openssl rand -hex 32
ADMIN_JWT_ACCESS_SECRET=change_me_to_a_random_64_char_hex_string
ADMIN_JWT_ACCESS_TTL=15m
ADMIN_REFRESH_TOKEN_TTL_DAYS=30

# --- Customer sessions (Redis-backed) + guest cart cookie ---
SESSION_TTL_DAYS=30
GUEST_COOKIE_TTL_DAYS=365
# Generate with: openssl rand -hex 32
COOKIE_SECRET=change_me_to_a_random_64_char_hex_string
# Set to false only for local http:// development
COOKIE_SECURE=true

# --- OTP (admin + customer email codes) ---
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# --- Mail (MailHog in dev — see docker-compose.yml; point at a real SMTP relay in production) ---
EMAIL_FROM=no-reply@example.com

# --- API docs ---
# Never enable in production unless the /api/v1/docs route is access-controlled.
SWAGGER_ENABLED=false

# --- Rate limiting (global baseline; auth/OTP routes have their own stricter limits) ---
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW=1 minute

# --- First-run admin seed (backend/src/db/seed.ts) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me_immediately
