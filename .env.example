# Copy this file to the repository-root .env used by Docker Compose.
# Never commit .env or .env.local — only this example file is tracked in git.

# --- Database (PostgreSQL 15+, via Prisma) ---
# Local Docker Compose default (see docker-compose.yml): matches POSTGRES_* below.
DATABASE_URL="postgresql://ecommerce:change_me@db:5432/ecommerce?schema=public"

# Used by the docker-compose.yml Postgres service — keep these in sync with DATABASE_URL above.
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change_me

# --- Authentication (JWT + bcrypt, custom implementation) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=
APP_ORIGIN=http://localhost:3000
ADDITIONAL_ALLOWED_ORIGINS=
TRUST_PROXY=false
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_CHECKOUT_MAX=10
RATE_LIMIT_MEDIA_UPLOAD_MAX=30
APP_CURRENCY=USD
APP_LOCALE=en-US
NEXT_PUBLIC_APP_CURRENCY=USD
NEXT_PUBLIC_APP_LOCALE=en-US
APP_VERSION=0.1.0

# --- Product media (local persistent storage) ---
# Only "local" is operational. The browser receives resolved URLs, never this path.
MEDIA_STORAGE_DRIVER=local
MEDIA_LOCAL_ROOT=/app/uploads
MEDIA_PUBLIC_PATH=/media
MEDIA_PUBLIC_BASE_URL=http://localhost:3000
MEDIA_MAX_FILE_SIZE_BYTES=5242880
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
MEDIA_MAX_IMAGES_PER_PRODUCT=8
MEDIA_MAX_IMAGE_PIXELS=40000000

# --- Seeded admin account (prisma/seed.ts) ---
# The one admin account the seed script creates/updates. Change these and
# re-run the seed to change the admin login — no code edit required.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# Cloud providers are intentionally not configured in this phase. Future provider
# credentials must remain private and must never use a NEXT_PUBLIC_* variable.
