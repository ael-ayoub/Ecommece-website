# Copy this file to .env.local for local development and fill in real values.
# Never commit .env or .env.local — only this example file is tracked in git.

# --- Database (PostgreSQL 15+, via Prisma) ---
# Local Docker Compose default (see docker-compose.yml): matches POSTGRES_* below.
DATABASE_URL="postgresql://ecommerce:change_me@localhost:5432/ecommerce?schema=public"

# Used by the docker-compose.yml Postgres service — keep these in sync with DATABASE_URL above.
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change_me

# --- Authentication (JWT + bcrypt, custom implementation) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=

# --- Seeded admin account (prisma/seed.ts) ---
# The one admin account the seed script creates/updates. Change these and
# re-run the seed to change the admin login — no code edit required.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# --- Cloudinary (image handling) — added when product image upload is implemented ---
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Supabase Realtime (admin real-time order updates) — added when real-time is implemented ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
