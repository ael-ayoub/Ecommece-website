// Prisma schema — self-hosted ecommerce admin + client API
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  STAFF
}

enum Locale {
  ar
  fr
  en
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────
// Admin-side auth & audit (fully isolated from customer tables)
// ─────────────────────────────────────────────────────────────

model Admin {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  password_hash String
  role          AdminRole @default(STAFF)
  is_disabled   Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  otp_codes       AdminOtpCode[]
  refresh_tokens  AdminRefreshToken[]
  password_resets AdminPasswordReset[]
  audit_logs      AuditLog[]

  @@map("admins")
}

model AdminOtpCode {
  id         String   @id @default(uuid()) @db.Uuid
  admin_id   String   @db.Uuid
  code_hash  String
  expires_at DateTime
  attempts   Int      @default(0)
  created_at DateTime @default(now())

  admin Admin @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@map("admin_otp_codes")
}

model AdminRefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  admin_id   String   @db.Uuid
  token_hash String
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())

  admin Admin @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@map("admin_refresh_tokens")
}

model AdminPasswordReset {
  id         String    @id @default(uuid()) @db.Uuid
  admin_id   String    @db.Uuid
  code_hash  String
  expires_at DateTime
  used_at    DateTime?

  admin Admin @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@map("admin_password_resets")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  admin_id     String   @db.Uuid
  action       String
  entity_type  String
  entity_id    String
  before_value Json?
  after_value  Json?
  created_at   DateTime @default(now())

  admin Admin @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@index([entity_type, entity_id])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// Customer-side auth (fully isolated from admin tables)
// ─────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String?  @unique
  password_hash String?
  full_name     String
  locale        Locale   @default(en)
  is_disabled   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  refresh_tokens  RefreshToken[]
  password_resets PasswordReset[]
  addresses       Address[]
  carts           Cart[]
  orders          Order[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

model PasswordReset {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  code_hash  String
  expires_at DateTime
  used_at    DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_resets")
}

model Address {
  id             String  @id @default(uuid()) @db.Uuid
  user_id        String  @db.Uuid
  address_line   String
  phone_home     String?
  phone_personal String?
  is_default     Boolean @default(false)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────

model Category {
  id         String   @id @default(uuid()) @db.Uuid
  parent_id  String?  @db.Uuid
  name       String
  slug       String   @unique
  image_url  String?
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())

  parent   Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parent_id])
  @@map("categories")
}

model Product {
  id             String  @id @default(uuid()) @db.Uuid
  category_id    String  @db.Uuid
  name           String
  slug           String  @unique
  description    String?

  // customer-facing price
  price          Decimal @db.Decimal(12, 2)

  // internal-only fields — NEVER exposed via customer API
  cost_price     Decimal @db.Decimal(12, 2)
  stock_real     Int     @default(0)

  // quantity tied up in pending/processing/shipped orders not yet delivered/cancelled
  stock_reserved Int     @default(0)

  // number actually shown to customers (can be capped below stock_real)
  stock_display  Int     @default(0)

  is_enabled Boolean @default(true)
  is_deleted Boolean @default(false)

  images     Json     @default("[]")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  category    Category    @relation(fields: [category_id], references: [id], onDelete: Restrict)
  cart_items  CartItem[]
  order_items OrderItem[]

  @@index([category_id])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────
// Cart
// ─────────────────────────────────────────────────────────────

model Cart {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String?  @db.Uuid
  guest_id   String?
  updated_at DateTime @updatedAt

  user  User?      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([user_id])
  @@index([guest_id])
  @@map("carts")
}

model CartItem {
  id         String @id @default(uuid()) @db.Uuid
  cart_id    String @db.Uuid
  product_id String @db.Uuid
  quantity   Int

  cart    Cart    @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Restrict)

  @@index([cart_id])
  @@index([product_id])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────────────────
// Orders
// ─────────────────────────────────────────────────────────────

model Order {
  id     String  @id @default(uuid()) @db.Uuid
  user_id String? @db.Uuid
  guest_id String?

  // filled only for guest orders
  guest_name           String?
  guest_phone_home     String?
  guest_phone_personal String?
  guest_address        String?
  guest_email          String?

  status OrderStatus @default(PENDING)

  // snapshot of the delivery fee at order time — never a live reference
  delivery_cost Decimal @db.Decimal(12, 2)

  // sum of order_items, before delivery
  total_amount Decimal @db.Decimal(12, 2)

  idempotency_key String? @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user  User?       @relation(fields: [user_id], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([user_id])
  @@index([guest_email])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  order_id   String  @db.Uuid
  product_id String  @db.Uuid
  quantity   Int

  // snapshots at time of order — never reference live product fields
  unit_price      Decimal @db.Decimal(12, 2)
  unit_cost_price Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Restrict)

  @@index([order_id])
  @@index([product_id])
  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────
// Store settings — single-row table
// ─────────────────────────────────────────────────────────────

model StoreSettings {
  id                     Int      @id @default(1)
  store_name             String
  store_logo_url         String?
  contact_email          String
  contact_phone          String?
  contact_address        String?
  currency               String   @default("USD")
  default_locale         Locale   @default(en)
  enabled_locales        Locale[] @default([en])
  guest_checkout_enabled Boolean  @default(true)
  low_stock_threshold    Int      @default(5)
  default_delivery_cost  Decimal  @db.Decimal(12, 2) @default(0)
  order_status_labels    Json?
  admin_notification_email String

  @@map("store_settings")
}
