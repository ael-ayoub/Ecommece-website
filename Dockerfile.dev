# Dev-mode image — used only by docker-compose.dev.yml (`make dev`). Unlike
# the production Dockerfile, this does NOT bake in the source or build a
# static .next output: the container installs dependencies, then the actual
# source is bind-mounted in at runtime by docker-compose.dev.yml, and
# `next dev` watches it — so edits on the host show up immediately, no
# rebuild required. Not used for production; keep prod behavior in Dockerfile.

FROM node:20-alpine
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY prisma ./prisma
RUN npx prisma generate

EXPOSE 3000

CMD ["npm", "run", "dev"]
